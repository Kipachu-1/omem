# copy to .env and edit — the CLI loads this file automatically; real env vars win over it

# vault to index (required unless you pass --vault)
OMEM_VAULT=/path/to/your/vault

# git auto-sync: 1 = commit+push dirty ticks, pull periodically
OMEM_GIT=1

# full-sync sweep + git tick interval, seconds
OMEM_POLL=30

# how often to pull remote changes, seconds (default 300)
#OMEM_GIT_PULL_INTERVAL=300

# explicit GitHub PAT — omit to use machine credentials (keychain / gh / store)
#GITHUB_TOKEN=github_pat_xxx

# embedding model (default Xenova/multilingual-e5-small; changing requires `omem rebuild`)
#OMEM_EMBED_MODEL=Xenova/multilingual-e5-small

# index location (default <vault>/.omem/index.db)
#OMEM_DB_PATH=
